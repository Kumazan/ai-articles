# Copy to .env (never commit real keys)

CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Private key used for L1 auth (create/derive API key) and signing orders (later)
POLYMARKET_PRIVATE_KEY=

# Optional: If you already have L2 creds, put them here; otherwise leave blank and we will derive.
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Mode
MODE=paper   # paper|live

# Scanner settings
ARB_SCAN_ENABLED=1
ARB_SCAN_INTERVAL_S=30
ARB_SCAN_MAX_MARKETS=200
ARB_SCAN_MAX_OUTCOMES=12
ARB_MIN_PROFIT_PCT=0.005
ARB_SCAN_PAGES=8
ARB_UNIVERSE_TTL_S=300
ARB_USE_REWARDS_UNIVERSE=1
ARB_REWARDS_MARKETS=160
ARB_CONCURRENCY=10
ARB_MAX_SHARES=50
ARB_SHARE_STEP=5
# Skip tiny-arb sizes: enforce per-leg minimum shares >= this (use market min_order_size when available)
ARB_MIN_SHARES=5

# Paper-fill (simulation) for arb opportunities
PAPER_FILL_ENABLED=1
PAPER_FILL_MAX_TRADES_PER_SCAN=1

# 15m up/down watcher
WATCH_15M_ENABLED=1
WATCH_15M_POLL_MS=800
SUMMARY_EVERY_S=15

# Data output
DATA_DIR=./data
