# Copy to .env and fill in. Never commit real keys.

# Wallet key (Polygon). Use the same key you shared; store it in /root/.openclaw/workspace/.secrets/polymarket.env
POLYMARKET_PRIVATE_KEY=

# Polymarket CLOB endpoints
CLOB_HOST=https://clob.polymarket.com
CLOB_WS=wss://ws-subscribe.polymarket.com

# 15m crypto markets (condition ids) + token ids (outcome tokens)
BTC_CONDITION_ID=0x42cdb907ccaef6090f870991a46b6f55b91e84549dab7f3485c6ec7aad704b7e
BTC_TOKEN_UP=43773962100434178965857797974893622004490483276951470121546828248288248240047
BTC_TOKEN_DOWN=16651226650374941944091460940831787707407180159998044677698934346343800660044

ETH_CONDITION_ID=0xa5bf0d9347374f6371cc0ae349dc68e9922a4725bc8d63abe5eb167ea4a52bdb
ETH_TOKEN_UP=105315820613731930941786033578730693104990017419543556092608076895580623876065
ETH_TOKEN_DOWN=103757150853838691970005145584774440190353088119004574351712717791978261498659

SOL_CONDITION_ID=0x15c5590e0d0220b95647d314b8ee49a8b69c919956531c4040cadd1186b8b5a6
