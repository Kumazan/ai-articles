# Strategy / paper trading
MODE=paper   # paper|live
EDGE_THRESHOLD=0.021
SLIPPAGE_BPS=20
LATENCY_BPS=30
LOG_DIR=./data

# Structural arb scanner (multi-outcome)
ARB_SCAN_ENABLED=1
ARB_SCAN_INTERVAL_MS=30000
ARB_SCAN_MAX_MARKETS=120
ARB_SCAN_MAX_OUTCOMES=12
ARB_MIN_PROFIT_PCT=0.005
